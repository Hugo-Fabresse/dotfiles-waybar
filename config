{
  "layer": "top",
  "position": "top",
  "height": 24,
  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["pulseaudio", "battery", "network"],

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "蟀潫 muted",
    "format-icons": {
      "default": ["蟀暱", "蟀杸", "蟀暰"]
    },
    "on-click": "pavucontrol",
    "tooltip": false
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "蟀倓 {capacity}%",
    "format-plugged": "蟀殽 {capacity}%",
    "format-icons": ["蟀伜", "蟀伝", "蟀伡", "蟀伣", "蟀伨", "蟀伩", "蟀個", "蟀倎", "蟀倐", "蟀伖"]
  },

  "network": {
    "format-wifi": "蟀え {essid}",
    "format-ethernet": "蟀垁 connected",
    "format-disconnected": "蟀き disconnected",
    "on-click": "nm-connection-editor",
    "tooltip": false
  },

  "clock": {
    "format": " {:%H:%M}",
    "on-click": "~/.local/bin/launch_calendar.sh",
    "tooltip": false
  },

  "hyprland/workspaces": {
    "format": "{id}",
    "on-click": "activate"
  }
}
