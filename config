{
  "layer": "top",
  "position": "top",
  "height": 24,
  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["custom/notifs", "pulseaudio", "battery", "network"],

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "َ°‌ں muted",
    "format-icons": {
      "default": ["َ°•؟", "َ°–€", "َ°•¾"]
    },
    "on-click": "pavucontrol",
    "tooltip": false
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "َ°‚„ {capacity}%",
    "format-plugged": "َ°ڑ¥ {capacity}%",
    "format-icons": ["َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"]
  },

  "network": {
    "format-wifi": "َ°¤¨ {essid}",
    "format-ethernet": "َ°ˆ€ connected",
    "format-disconnected": "َ°¤­ disconnected",
    "on-click": "nm-connection-editor",
    "tooltip": false
  },

  "clock": {
    "format": " {:%H:%M}",
    "on-click": "~/.local/bin/launch_calendar.sh",
    "tooltip": false
  },

  "custom/notifs": {
    "exec": "~/.local/bin/notif_waybar.sh",
    "return-type": "json",
    "interval": 3,
    "on-click": "python3 ~/.local/bin/notif_panel.py",
    "tooltip": false
  },

  "hyprland/workspaces": {
    "format": "{id}",
    "on-click": "activate"
  }
}
